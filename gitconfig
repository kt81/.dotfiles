# Managed git configuration (tracked by dotfiles).
#
# ~/.gitconfig is a LOCAL file that `[include]`s this one and holds personal
# identity / credentials, so `git config --global ...` and tools like
# `gh auth setup-git` write to ~/.gitconfig without ever dirtying this repo.

[init]
	defaultBranch = main
[color]
	ui = auto
[column]
	ui = auto
[push]
	default = simple
	autoSetupRemote = true    # `git push` on a new branch just works
	followTags = true
[pull]
	rebase = false
[fetch]
	prune = true              # drop local refs for branches deleted upstream
	pruneTags = true
[core]
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
[rebase]
	autosquash = true
	autostash = true          # stash/pop dirty tree around a rebase
	updateRefs = true
[rerere]
	enabled = true            # remember & replay conflict resolutions
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
	algorithm = histogram
	mnemonicPrefix = true
[branch]
	sort = -committerdate     # `git branch` lists most-recent first
[tag]
	sort = version:refname
[help]
	autocorrect = prompt
[alias]
	co = checkout
	sw = switch
	re = restore
	ci = commit
	st = status
	br = branch
	kfetch = fetch --all --prune
	brmd = "!f() { git branch --merged | grep -vE '^[* ]*(main|master)$' | xargs -I% git branch -d %; }; f"
	kup = "!f() { b=${1:-main}; git fetch --all --prune && git switch \"$b\" && git merge --ff-only \"upstream/$b\" && git push origin \"$b\"; }; f"
